# ONE worker config — copy to .env and edit
ONE_GATEWAY=https://platform.onecompute.xyz
# Local OpenAI-compatible inference server (Ollama default shown).
# llama.cpp: http://localhost:8080/v1 · vLLM: http://localhost:8000/v1 · LM Studio: http://localhost:1234/v1
ONE_BACKEND=http://localhost:11434/v1
# Comma-separated models this hardware advertises (trimmed, de-duplicated, must be non-empty)
ONE_MODELS=llama3.1:8b
# Persistent worker key — your USDC payout identity (else payouts won't accrue):
#   openssl genpkey -algorithm ed25519 -out worker.key
# ONE_WORKER_KEY="$(cat worker.key)"
# Poll interval in ms (integer, minimum 250)
ONE_POLL_MS=2000
